# Database Configuration - PostgreSQL Cloud (REQUIRED)
# Get your connection string from:
# - Neon: https://neon.tech (Recommended, FREE tier)
# - Supabase: https://supabase.com (FREE tier)
# - Railway: https://railway.app
# Example: postgresql+asyncpg://user:pass@host:port/database

DATABASE_URL=postgresql+asyncpg://username:password@host:port/database
DATABASE_URL_SYNC=postgresql://username:password@host:port/database

# JWT Configuration
JWT_SECRET_KEY=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY=30

# AI Provider Selection (openai, gemini, ollama, auto)
AI_PROVIDER=openai

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Google Gemini Configuration
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# Ollama Configuration (Local Model)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Application Settings
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
DEBUG=True

# Email Configuration (Required for OTP verification)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# App URL (Used in email templates)
APP_URL=http://localhost:3000

# Database SSL (set to false for local PostgreSQL without SSL)
DATABASE_SSL=true

# Qdrant Vector Database (REQUIRED for search)
QDRANT_URL=https://your-cluster.qdrant.io:6333
QDRANT_API_KEY=your-qdrant-api-key

# Email Domain Restrictions
RESTRICTED_EMAIL_DOMAIN=@pvpsit.ac.in
ADMIN_EMAIL_DOMAIN=@pvpsiddhartha.ac.in

# DeepSeek Configuration (Optional)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=
