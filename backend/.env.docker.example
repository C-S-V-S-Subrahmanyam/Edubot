# Local Docker-backed environment for EduBot backend
# Copy this file to backend/.env before running with docker-compose services.

# PostgreSQL (docker-compose postgres service)
DATABASE_URL=postgresql+asyncpg://edubot:edubot@localhost:5432/edubot
DATABASE_URL_SYNC=postgresql://edubot:edubot@localhost:5432/edubot
DATABASE_SSL=false

# JWT
JWT_SECRET_KEY=change-this-secret-for-local-dev
JWT_ALGORITHM=HS256
JWT_EXPIRY=30

# CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DEBUG=true

# Vector DB (docker-compose qdrant service)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# AI provider defaults
DEFAULT_AI_PROVIDER=auto
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Email (optional for OTP in local dev)
EMAIL_USER=
EMAIL_PASS=

# Domain restrictions
RESTRICTED_EMAIL_DOMAIN=@pvpsit.ac.in
ADMIN_EMAIL_DOMAIN=@pvpsiddhartha.ac.in
